# --- PostgreSQL ---
# Для psycopg3 используйте префикс postgresql+psycopg://
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tender_parser

# --- Хранилище ---
# Каталог для скачанных/распарсенных тендеров (по умолчанию ./data)
# DATA_DIR=./data

# --- tenderplan.ru ---
TENDERPLAN_AUTH_KEY=

# --- LLM (OpenAI-compatible: xAI / OpenAI / LM Studio) ---
LLM_BASE_URL=https://api.x.ai
LLM_API_KEY=
LLM_MODEL=grok-4-fast-reasoning
LLM_PASSPORT_MODEL=grok-4-fast-non-reasoning

# --- Mistral OCR ---
MISTRAL_API_KEY=

# --- Исходящий прокси (опционально) ---
# OUTBOUND_PROXY_URL=http://user:pass@proxy.example.com:3128
# OUTBOUND_PROXY_BYPASS=tenderplan.ru

# --- Langfuse трейсинг (опционально) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Windows: путь к UnRAR для .rar архивов ---
# UNRAR_TOOL=C:\Program Files\UnRAR\UnRAR.exe
